# Build output
/yoloai

# Test artifacts
coverage.out
coverage.html
.tart-provisioned

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Claude Code — ignore personal config and runtime state, but track team-wide
# settings and hook scripts so cloned repos pick them up automatically.
.claude/*
!.claude/settings.json
!.claude/hooks/

# Temporary files
*.tmp

# Bug reports generated by --bugreport flag
yoloai-bugreport-*.md
yoloai-smoketest-*

# Smoke-test cache: per-run logs, last-good baselines, and the run index.
# Repo-local (not ~/.yoloai) so multiple checkouts don't clash; see
# scripts/smoke_test.py _testcache_root.
.testcache/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/

# GoReleaser build output + generated completions
/dist/
/completions/
