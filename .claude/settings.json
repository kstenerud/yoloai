{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/post-edit.sh"
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$PWD}/scripts/check_citation_provenance.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/on-stop.sh",
            "timeout": 300,
            "statusMessage": "Running make check..."
          }
        ]
      }
    ]
  }
}
